'use client';

import { useState, useEffect, useCallback, useRef } from 'react';
import Link from 'next/link';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { Badge } from '@/components/ui/badge';
import { Progress } from '@/components/ui/progress';
import { Input } from '@/components/ui/input';

// 客户端组件，避免hydration错误
function LastUpdatedTime() {
  const [currentTime, setCurrentTime] = useState('');
  
  useEffect(() => {
    setCurrentTime(new Date().toLocaleString());
  }, []);
  
  return <span>{currentTime || '加载中...'}</span>;
}

// 客户端时间格式化组件
function AlertTime({ timestamp }: { timestamp: string }) {
  const [formattedTime, setFormattedTime] = useState('');
  
  useEffect(() => {
    const date = new Date(timestamp);
    setFormattedTime(date.toLocaleTimeString());
  }, [timestamp]);
  
  return <span>{formattedTime || '加载中...'}</span>;
}
import { 
  Search, 
  Filter, 
  RefreshCw, 
  Plus, 
  Settings, 
  AlertTriangle, 
  CheckCircle, 
  XCircle,
  Wrench,
  Key,
  Cloud,
  Brain,
  Code,
  MessageSquare,
  BarChart3,
  Server,
  Globe,
  Eye,
  EyeOff,
  ChevronLeft,
  ChevronRight,
  MoreVertical,
  Edit,
  Trash2,
  TestTube,
  Shield,
  Download,
  Upload,
} from 'lucide-react';
import { ApiConfigForm } from '@/components/api-config-form';
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuLabel,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from '@/components/ui/dropdown-menu';
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from '@/components/ui/table';
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from '@/components/ui/select';

interface ExternalApi {
  id: string;
  name: string;
  provider: string;
  category: string;
  description: string;
  status: 'active' | 'inactive' | 'needs_setup' | 'error';
  lastChecked: string;
  lastResponseTime?: number;
  lastStatusCode?: number;
  lastError?: string;
  totalCalls: number;
  successfulCalls: number;
  failedCalls: number;
  averageResponseTime: number;
  tags: string[];
  createdAt: string;
  updatedAt: string;
}

interface ApiStats {
  totalApis: number;
  activeApis: number;
  inactiveApis: number;
  needsSetupApis: number;
  errorApis: number;
  byProvider: Record<string, number>;
  byCategory: Record<string, number>;
  totalCalls: number;
  successfulCalls: number;
  failedCalls: number;
  averageResponseTime: number;
}

interface ApiAlert {
  id: string;
  apiId: string;
  type: string;
  severity: 'low' | 'medium' | 'high' | 'critical';
  message: string;
  resolved: boolean;
  createdAt: string;
}

export default function ExternalApisPage() {
  const [apis, setApis] = useState<ExternalApi[]>([]);
  const [stats, setStats] = useState<ApiStats | null>(null);
  const [alerts, setAlerts] = useState<ApiAlert[]>([]);
  const [loading, setLoading] = useState(true);
  const [searchQuery, setSearchQuery] = useState('');
  const [filterProvider, setFilterProvider] = useState<string>('all');
  const [filterCategory, setFilterCategory] = useState<string>('all');
  const [filterStatus, setFilterStatus] = useState<string>('all');
  
  // 分页状态
  const [currentPage, setCurrentPage] = useState(1);
  const [pageSize, setPageSize] = useState(10);
  const [totalPages, setTotalPages] = useState(1);
  
  // 详情视图状态
  const [selectedApi, setSelectedApi] = useState<ExternalApi | null>(null);
  const [showDetails, setShowDetails] = useState(false);

  // 加载数据
  // 检查API状态
  const checkApiStatus = async (apiId?: string) => {
    try {
      const url = apiId 
        ? `/api/external-apis?action=check&id=${apiId}`
        : '/api/external-apis?action=check';
      
      const response = await fetch(url, { method: 'GET' });
      const data = await response.json();
      
      if (data.success) {
        // 重新加载数据
        await loadInitialData();
        return true;
      }
      return false;
    } catch (error) {
      console.error('检查API状态失败:', error);
      return false;
    }
  };

  // 解决告警
  const resolveAlert = async (alertId: string) => {
    try {
      const response = await fetch('/api/external-apis', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'resolve-alert',
          id: alertId,
          resolvedBy: 'user'
        })
      });
      
      const data = await response.json();
      if (data.success) {
        // 重新加载告警
        const alertsResponse = await fetch('/api/external-apis?action=alerts&resolved=false&limit=5');
        const alertsData = await alertsResponse.json();
        if (alertsData.success) {
          setAlerts(alertsData.data.alerts || []);
        }
        return true;
      }
      return false;
    } catch (error) {
      console.error('解决告警失败:', error);
      return false;
    }
  };

  // 初始化加载
  useEffect(() => {
    console.log('🔧 useEffect执行，直接加载数据');
    
    const loadData = async () => {
      try {
        console.log('📡 直接加载API数据...');
        setLoading(true);
        
        // 加载API列表
        const apisResponse = await fetch('/api/external-apis');
        const apisData = await apisResponse.json();
        console.log('📊 API数据:', apisData.success ? '成功' : '失败', '长度:', apisData.data?.apis?.length || 0);
        
        if (apisData.success) {
          const apiList = apisData.data.apis || [];
          console.log('📋 直接设置API列表:', apiList.length);
          setApis(apiList);
        }
        
        // 加载统计信息
        const statsResponse = await fetch('/api/external-apis?action=stats');
        const statsData = await statsResponse.json();
        if (statsData.success) {
          setStats(statsData.data);
        }
        
        // 加载告警
        const alertsResponse = await fetch('/api/external-apis?action=alerts&resolved=false&limit=5');
        const alertsData = await alertsResponse.json();
        if (alertsData.success) {
          setAlerts(alertsData.data.alerts || []);
        }
        
      } catch (error) {
        console.error('❌ 直接加载数据失败:', error);
      } finally {
        console.log('🔚 直接加载完成，设置loading=false');
        setLoading(false);
      }
    };
    
    loadData();
    
    // 每60秒自动刷新
    const interval = setInterval(loadData, 60000);
    return () => clearInterval(interval);
  }, []);

  // 调试：检查状态更新
  useEffect(() => {
    console.log('🔍 调试 - apis状态:', apis.length, 'loading状态:', loading);
  }, [apis, loading]);

  // 初始数据加载
  useEffect(() => {
    loadInitialData();
    
    // 每60秒刷新
    const interval = setInterval(() => {
      console.log('🔄 定时刷新数据');
      loadInitialData();
    }, 60000);
    
    return () => clearInterval(interval);
  }, []);

  // 过滤和分页逻辑
  const filteredApis = apis.filter(api => {
    // 搜索过滤
    if (searchQuery && !api.name.toLowerCase().includes(searchQuery.toLowerCase()) && 
        !api.description.toLowerCase().includes(searchQuery.toLowerCase())) {
      return false;
    }
    
    // 提供商过滤
    if (filterProvider !== 'all' && api.provider !== filterProvider) {
      return false;
    }
    
    // 类别过滤
    if (filterCategory !== 'all' && api.category !== filterCategory) {
      return false;
    }
    
    // 状态过滤
    if (filterStatus !== 'all' && api.status !== filterStatus) {
      return false;
    }
    
    return true;
  });

  // 计算分页
  useEffect(() => {
    const total = filteredApis.length;
    const pages = Math.ceil(total / pageSize);
    setTotalPages(pages > 0 ? pages : 1);
    
    // 如果当前页超过总页数，重置到第一页
    if (currentPage > pages) {
      setCurrentPage(1);
    }
  }, [filteredApis, pageSize, currentPage]);

  const paginatedApis = filteredApis.slice(
    (currentPage - 1) * pageSize,
    currentPage * pageSize
  );

  // 获取提供商选项
  const providerOptions = ['all', ...Array.from(new Set(apis.map(api => api.provider)))];
  const categoryOptions = ['all', ...Array.from(new Set(apis.map(api => api.category)))];

  // 状态颜色映射
  const getStatusColor = (status: string) => {
    switch (status) {
      case 'active': return 'bg-emerald-100 text-emerald-800 border-emerald-200';
      case 'inactive': return 'bg-slate-100 text-slate-800 border-slate-200';
      case 'needs_setup': return 'bg-amber-100 text-amber-800 border-amber-200';
      case 'error': return 'bg-rose-100 text-rose-800 border-rose-200';
      default: return 'bg-slate-100 text-slate-800 border-slate-200';
    }
  };

  const getStatusIcon = (status: string) => {
    switch (status) {
      case 'active': return <CheckCircle className="h-4 w-4" />;
      case 'inactive': return <EyeOff className="h-4 w-4" />;
      case 'needs_setup': return <Wrench className="h-4 w-4" />;
      case 'error': return <XCircle className="h-4 w-4" />;
      default: return <Eye className="h-4 w-4" />;
    }
  };

  // 提供商图标映射
  const getProviderIcon = (provider: string) => {
    switch (provider) {
      case 'google': return <Globe className="h-4 w-4" />;
      case 'openai': return <Brain className="h-4 w-4" />;
      case 'anthropic': return <Brain className="h-4 w-4" />;
      case 'deepseek': return <Brain className="h-4 w-4" />;
      case 'github': return <Code className="h-4 w-4" />;
      case 'azure': return <Cloud className="h-4 w-4" />;
      case 'linkedin': return <MessageSquare className="h-4 w-4" />;
      case 'brave': return <Search className="h-4 w-4" />;
      default: return <Server className="h-4 w-4" />;
    }
  };

  // 类别图标映射
  const getCategoryIcon = (category: string) => {
    switch (category) {
      case 'ai': return <Brain className="h-4 w-4" />;
      case 'cloud': return <Cloud className="h-4 w-4" />;
      case 'analytics': return <BarChart3 className="h-4 w-4" />;
      case 'development': return <Code className="h-4 w-4" />;
      case 'social': return <MessageSquare className="h-4 w-4" />;
      case 'search': return <Search className="h-4 w-4" />;
      case 'audio': return <MessageSquare className="h-4 w-4" />;
      case 'ads': return <BarChart3 className="h-4 w-4" />;
      default: return <Server className="h-4 w-4" />;
    }
  };

  // 严重度颜色映射
  const getSeverityColor = (severity: string) => {
    switch (severity) {
      case 'critical': return 'bg-rose-100 text-rose-800 border-rose-200';
      case 'high': return 'bg-orange-100 text-orange-800 border-orange-200';
      case 'medium': return 'bg-amber-100 text-amber-800 border-amber-200';
      case 'low': return 'bg-blue-100 text-blue-800 border-blue-200';
      default: return 'bg-slate-100 text-slate-800 border-slate-200';
    }
  };

  return (
    <div className="container mx-auto px-4 py-8">
      <div className="max-w-6xl mx-auto space-y-6">
        {/* 标题和控制栏 */}
        <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
          <div>
            <h1 className="text-3xl font-bold flex items-center gap-2">
              <Globe className="h-8 w-8" />
              外部API监控中心
              {loading && (
                <span className="text-sm font-normal text-slate-500 ml-2">
                  <span className="animate-spin inline-block h-4 w-4 border-b-2 border-slate-500 rounded-full mr-1"></span>
                  加载中...
                </span>
              )}
            </h1>
            <p className="text-muted-foreground">监控和管理所有外部API服务的状态和配置</p>
            <p className="text-xs text-slate-500 mt-1">API数量: {apis.length} | 加载状态: {loading ? '加载中' : '完成'}</p>
          </div>
          <div className="flex flex-wrap items-center gap-2 md:gap-3">
            <Button
              variant="outline"
              size="md"
              onClick={() => checkApiStatus()}
            >
              <RefreshCw className="h-4 w-4 mr-2" />
              检查所有API
            </Button>
            <Link href="/external-apis/detailed">
              <Button variant="outline" size="md">
                <BarChart3 className="h-4 w-4 mr-2" />
                详细列表
              </Button>
            </Link>
            <ApiConfigForm onSuccess={loadInitialData} />
            <Button variant="outline" size="md">
              <Settings className="h-4 w-4 mr-2" />
              设置
            </Button>
          </div>
        </div>

        {/* 统计卡片 */}
        {stats && (
          <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
            <Card>
              <CardContent className="pt-6">
                <div className="text-center">
                  <div className="text-2xl font-bold">{stats.totalApis}</div>
                  <div className="text-sm text-slate-500">总API数</div>
                </div>
              </CardContent>
            </Card>
            
            <Card className="border-emerald-200">
              <CardContent className="pt-6">
                <div className="text-center">
                  <div className="text-2xl font-bold text-emerald-600">{stats.activeApis}</div>
                  <div className="text-sm text-slate-500">活跃</div>
                </div>
              </CardContent>
            </Card>
            
            <Card className="border-amber-200">
              <CardContent className="pt-6">
                <div className="text-center">
                  <div className="text-2xl font-bold text-amber-600">{stats.needsSetupApis}</div>
                  <div className="text-sm text-slate-500">待配置</div>
                </div>
              </CardContent>
            </Card>
            
            <Card className="border-rose-200">
              <CardContent className="pt-6">
                <div className="text-center">
                  <div className="text-2xl font-bold text-rose-600">{stats.errorApis}</div>
                  <div className="text-sm text-slate-500">错误</div>
                </div>
              </CardContent>
            </Card>
            
            <Card>
              <CardContent className="pt-6">
                <div className="text-center">
                  <div className="text-2xl font-bold">{stats.successfulCalls}</div>
                  <div className="text-sm text-slate-500">成功调用</div>
                </div>
              </CardContent>
            </Card>
            
            <Card>
              <CardContent className="pt-6">
                <div className="text-center">
                  <div className="text-2xl font-bold">{Math.round(stats.averageResponseTime)}ms</div>
                  <div className="text-sm text-slate-500">平均响应</div>
                </div>
              </CardContent>
            </Card>
          </div>
        )}

        {/* 告警面板 */}
        {alerts.length > 0 && (
          <Card className="border-rose-200">
            <CardHeader className="pb-3">
              <CardTitle className="text-sm font-medium text-rose-700 flex items-center gap-2">
                <AlertTriangle className="h-4 w-4" />
                活跃告警 ({alerts.length})
              </CardTitle>
            </CardHeader>
            <CardContent className="pt-6">
              <div className="space-y-2">
                {alerts.map((alert) => (
                  <div
                    key={alert.id}
                    className={`p-3 rounded-lg ${getSeverityColor(alert.severity)}`}
                  >
                    <div className="flex items-start justify-between">
                      <div className="flex-1">
                        <div className="font-medium text-sm">{alert.message}</div>
                        <div className="text-xs text-slate-600 mt-1">
                          API ID: {alert.apiId} | 时间: <AlertTime timestamp={alert.createdAt} />
                        </div>
                      </div>
                      <Button
                        variant="ghost"
                        size="sm"
                        className="ml-2"
                        onClick={() => resolveAlert(alert.id)}
                      >
                        解决
                      </Button>
                    </div>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        )}

        {/* 过滤和搜索栏 */}
        <Card>
          <CardContent className="p-6">
            <div className="flex flex-col md:flex-row gap-4">
              <div className="flex-1">
                <div className="relative">
                  <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 h-4 w-4 text-slate-400" />
                  <Input
                    placeholder="搜索API名称或描述..."
                    className="pl-10"
                    value={searchQuery}
                    onChange={(e) => setSearchQuery(e.target.value)}
                  />
                </div>
              </div>
              
              <div className="flex gap-2">
                <Select value={filterProvider} onValueChange={setFilterProvider}>
                  <SelectTrigger className="w-[140px]">
                    <SelectValue placeholder="提供商" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="all">所有提供商</SelectItem>
                    {providerOptions.filter(p => p !== 'all').map(provider => (
                      <SelectItem key={provider} value={provider}>
                        <div className="flex items-center gap-2">
                          {getProviderIcon(provider)}
                          <span className="capitalize">{provider}</span>
                        </div>
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
                
                <Select value={filterCategory} onValueChange={setFilterCategory}>
                  <SelectTrigger className="w-[140px]">
                    <SelectValue placeholder="类别" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="all">所有类别</SelectItem>
                    {categoryOptions.filter(c => c !== 'all').map(category => (
                      <SelectItem key={category} value={category}>
                        <div className="flex items-center gap-2">
                          {getCategoryIcon(category)}
                          <span className="capitalize">{category}</span>
                        </div>
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
                
                <Select value={filterStatus} onValueChange={setFilterStatus}>
                  <SelectTrigger className="w-[140px]">
                    <SelectValue placeholder="状态" />
                  </SelectTrigger>
                  <SelectContent>
                    <SelectItem value="all">所有状态</SelectItem>
                    <SelectItem value="active">活跃</SelectItem>
                    <SelectItem value="inactive">未激活</SelectItem>
                    <SelectItem value="needs_setup">待配置</SelectItem>
                    <SelectItem value="error">错误</SelectItem>
                  </SelectContent>
                </Select>
              </div>
            </div>
          </CardContent>
        </Card>

        {/* API列表表格 */}
        <Card>
          <CardHeader>
            <CardTitle className="text-sm font-medium">外部API列表</CardTitle>
            <CardDescription>
              共 {filteredApis.length} 个API，显示第 {(currentPage - 1) * pageSize + 1} - {Math.min(currentPage * pageSize, filteredApis.length)} 个
            </CardDescription>
          </CardHeader>
          <CardContent className="p-6">
            <div className="overflow-x-auto">
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead className="w-[200px] lg:w-[250px]">API名称</TableHead>
                    <TableHead className="hidden sm:table-cell">提供商</TableHead>
                    <TableHead className="hidden md:table-cell">类别</TableHead>
                    <TableHead>状态</TableHead>
                    <TableHead className="hidden lg:table-cell">响应时间</TableHead>
                    <TableHead className="hidden lg:table-cell">调用统计</TableHead>
                    <TableHead className="text-right w-[140px]">操作</TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  {paginatedApis.length === 0 ? (
                    <TableRow>
                      <TableCell colSpan={4} className="text-center py-8 text-slate-500">
                        没有找到匹配的API
                      </TableCell>
                    </TableRow>
                  ) : (
                    paginatedApis.map((api) => (
                      <TableRow key={api.id} className="hover:bg-slate-50">
                        <TableCell>
                          <div>
                            <div className="font-medium">{api.name}</div>
                            <div className="text-xs text-slate-500 truncate max-w-[180px] lg:max-w-[230px]">
                              {api.description}
                            </div>
                          </div>
                        </TableCell>
                        <TableCell className="hidden sm:table-cell">
                          <div className="flex items-center gap-2">
                            {getProviderIcon(api.provider)}
                            <span className="capitalize">{api.provider}</span>
                          </div>
                        </TableCell>
                        <TableCell className="hidden md:table-cell">
                          <div className="flex items-center gap-2">
                            {getCategoryIcon(api.category)}
                            <span className="capitalize">{api.category}</span>
                          </div>
                        </TableCell>
                        <TableCell>
                          <Badge variant="outline" className={getStatusColor(api.status)}>
                            <div className="flex items-center gap-1">
                              {getStatusIcon(api.status)}
                              <span className="capitalize">
                                {api.status === 'active' ? '活跃' :
                                 api.status === 'inactive' ? '未激活' :
                                 api.status === 'needs_setup' ? '待配置' : '错误'}
                              </span>
                            </div>
                          </Badge>
                        </TableCell>
                        <TableCell className="hidden lg:table-cell">
                          <div className="space-y-1">
                            <div className="text-sm">
                              {api.lastResponseTime ? `${api.lastResponseTime}ms` : '--'}
                            </div>
                            {api.averageResponseTime > 0 && (
                              <div className="text-xs text-slate-500">
                                平均: {Math.round(api.averageResponseTime)}ms
                              </div>
                            )}
                          </div>
                        </TableCell>
                        <TableCell className="hidden lg:table-cell">
                          <div className="space-y-1">
                            <div className="text-sm">
                              总计: {api.totalCalls}
                            </div>
                            <div className="flex items-center gap-2">
                              <div className="text-xs text-emerald-600">
                                成功: {api.successfulCalls}
                              </div>
                              <div className="text-xs text-rose-600">
                                失败: {api.failedCalls}
                              </div>
                            </div>
                            {api.totalCalls > 0 && (
                              <Progress 
                                value={(api.successfulCalls / api.totalCalls) * 100} 
                                className="h-1.5" 
                              />
                            )}
                          </div>
                        </TableCell>
                        <TableCell className="text-right">
                          <div className="flex justify-end gap-1">
                            <Button
                              variant="ghost"
                              size="sm"
                              onClick={() => checkApiStatus(api.id)}
                              title="检查状态"
                            >
                              <RefreshCw className="h-4 w-4" />
                            </Button>
                            <Button
                              variant="ghost"
                              size="sm"
                              onClick={() => setSelectedApi(api)}
                              title="查看详情"
                            >
                              <Eye className="h-4 w-4" />
                            </Button>
                            <Button
                              variant="ghost"
                              size="sm"
                              title="测试连接"
                            >
                              <TestTube className="h-4 w-4" />
                            </Button>
                            <ApiConfigForm 
                              apiId={api.id}
                              apiName={api.name}
                              provider={api.provider}
                              category={api.category}
                              onSuccess={loadInitialData}
                            />
                            <DropdownMenu>
                              <DropdownMenuTrigger asChild>
                                <Button variant="ghost" size="sm">
                                  <MoreVertical className="h-4 w-4" />
                                </Button>
                              </DropdownMenuTrigger>
                              <DropdownMenuContent align="end">
                                <DropdownMenuLabel>其他操作</DropdownMenuLabel>
                                <DropdownMenuItem>
                                  <Key className="h-4 w-4 mr-2" />
                                  快速更新密钥
                                </DropdownMenuItem>
                                <DropdownMenuItem>
                                  <Shield className="h-4 w-4 mr-2" />
                                  安全审计
                                </DropdownMenuItem>
                                <DropdownMenuSeparator />
                                <DropdownMenuItem className="text-rose-600">
                                  <Trash2 className="h-4 w-4 mr-2" />
                                  删除API
                                </DropdownMenuItem>
                              </DropdownMenuContent>
                            </DropdownMenu>
                          </div>
                        </TableCell>
                      </TableRow>
                    ))
                  )}
                </TableBody>
              </Table>
            </div>

            {/* 分页控件 */}
            {filteredApis.length > 0 && (
              <div className="flex items-center justify-between mt-6">
                <div className="text-sm text-slate-500">
                  每页显示
                  <Select value={pageSize.toString()} onValueChange={(v) => setPageSize(parseInt(v))}>
                    <SelectTrigger className="w-[80px] inline-flex mx-2">
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="5">5</SelectItem>
                      <SelectItem value="10">10</SelectItem>
                      <SelectItem value="20">20</SelectItem>
                      <SelectItem value="50">50</SelectItem>
                    </SelectContent>
                  </Select>
                  条
                </div>
                
                <div className="flex items-center gap-2">
                  <Button
                    variant="outline"
                    size="sm"
                    onClick={() => setCurrentPage(prev => Math.max(1, prev - 1))}
                    disabled={currentPage === 1}
                  >
                    <ChevronLeft className="h-4 w-4" />
                  </Button>
                  
                  <div className="flex items-center gap-1">
                    {Array.from({ length: Math.min(5, totalPages) }, (_, i) => {
                      let pageNum;
                      if (totalPages <= 5) {
                        pageNum = i + 1;
                      } else if (currentPage <= 3) {
                        pageNum = i + 1;
                      } else if (currentPage >= totalPages - 2) {
                        pageNum = totalPages - 4 + i;
                      } else {
                        pageNum = currentPage - 2 + i;
                      }
                      
                      return (
                        <Button
                          key={pageNum}
                          variant={currentPage === pageNum ? "default" : "outline"}
                          size="sm"
                          className="w-8 h-8 p-0"
                          onClick={() => setCurrentPage(pageNum)}
                        >
                          {pageNum}
                        </Button>
                      );
                    })}
                    
                    {totalPages > 5 && currentPage < totalPages - 2 && (
                      <>
                        <span className="px-2">...</span>
                        <Button
                          variant="outline"
                          size="sm"
                          className="w-8 h-8 p-0"
                          onClick={() => setCurrentPage(totalPages)}
                        >
                          {totalPages}
                        </Button>
                      </>
                    )}
                  </div>
                  
                  <Button
                    variant="outline"
                    size="sm"
                    onClick={() => setCurrentPage(prev => Math.min(totalPages, prev + 1))}
                    disabled={currentPage === totalPages}
                  >
                    <ChevronRight className="h-4 w-4" />
                  </Button>
                </div>
                
                <div className="text-sm text-slate-500">
                  第 {currentPage} / {totalPages} 页
                </div>
              </div>
            )}
          </CardContent>
        </Card>

        {/* 操作指南 */}
        <Card>
          <CardHeader>
            <CardTitle className="text-sm font-medium">操作指南</CardTitle>
          </CardHeader>
          <CardContent className="p-6">
            <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div className="space-y-2">
                <h4 className="font-medium text-sm flex items-center gap-2">
                  <Key className="h-4 w-4" />
                  添加新API
                </h4>
                <ul className="text-sm text-slate-600 space-y-1">
                  <li>1. 点击"添加API"按钮</li>
                  <li>2. 填写API基本信息</li>
                  <li>3. 配置认证信息</li>
                  <li>4. 保存并测试连接</li>
                </ul>
              </div>
              
              <div className="space-y-2">
                <h4 className="font-medium text-sm flex items-center gap-2">
                  <Wrench className="h-4 w-4" />
                  故障排除
                </h4>
                <ul className="text-sm text-slate-600 space-y-1">
                  <li>• 检查API密钥是否过期</li>
                  <li>• 验证网络连接</li>
                  <li>• 检查API配额限制</li>
                  <li>• 查看错误日志详情</li>
                </ul>
              </div>
              
              <div className="space-y-2">
                <h4 className="font-medium text-sm flex items-center gap-2">
                  <Shield className="h-4 w-4" />
                  安全建议
                </h4>
                <ul className="text-sm text-slate-600 space-y-1">
                  <li>• 定期轮换API密钥</li>
                  <li>• 使用最小必要权限</li>
                  <li>• 监控异常调用模式</li>
                  <li>• 启用API使用审计</li>
                </ul>
              </div>
            </div>
          </CardContent>
        </Card>

        {/* 页脚 */}
        <div className="text-center text-sm text-slate-500 pt-4">
          <p>外部API监控数据每60秒自动刷新 • 最后更新: <LastUpdatedTime /></p>
          <p className="mt-1">
            支持: Google APIs • OpenAI • Anthropic • GitHub • Azure • LinkedIn • Brave Search
          </p>
        </div>
      </div>
    </div>
  );
}