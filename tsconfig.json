{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noImplicitAny": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": [
    "node_modules",
    "src/lib/requirements-analysis/grok-ai-service.ts",
    "src/lib/requirements-analysis/requirements-analyzer-service.ts",
    "src/lib/requirements-analysis/requirements-analyzer-service-complete.ts",
    "src/lib/requirements-analysis/technical-document-generator.ts",
    "src/lib/requirements-analysis/technical-document-generator-complete.ts",
    "src/lib/requirements-analysis/document-parser-service.ts",
    "src/components/requirements-analysis/visual-dashboard.tsx",
    "src/components/requirements-analysis/visualization-dashboard.tsx",
    "src/app/external-apis/page-fixed.tsx",
    "src/app/system-monitoring/page-full.tsx",
    "src/app/system-monitoring/page-completion.tsx",
    "src/__tests__/**",
    "src/app/external-apis/**",
    "src/app/api/external-apis/route.ts",
    "src/components/api-config-form.tsx",
    "src/components/external-api-monitoring.tsx",
    "src/modules/**",
    "src/modules/health/**",
    "src/shared/**",
    "src/lib/finance-db-service.ts",
    "src/lib/postgres-store.ts",
    "src/app/knowledge-dev-deleted/page.tsx",
    "src/app/freelance/page.tsx",
    "src/app/missions/page.tsx",
    "src/app/analytics/page.tsx"
  ]
}
