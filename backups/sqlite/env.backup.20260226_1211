# Mission Control 生产环境配置
# 复制此文件为 .env.production 并修改值

# ========== 应用配置 ==========
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# ========== 数据库配置 ==========
# SQLite (默认，简单)
DATABASE_URL=file:./data/mission-control.db

# PostgreSQL (生产推荐)
# DATABASE_URL=postgresql://mission_user:your_password@postgres:5432/mission_control

# ========== 安全配置 ==========
# NextAuth 密钥 (生成: openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret_key_here
NEXTAUTH_URL=https://mission-control.yourdomain.com

# API 密钥
API_SECRET_KEY=your_api_secret_key_here
JWT_SECRET=your_jwt_secret_key_here

# ========== 功能开关 ==========
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_AUTOMATION=true
ENABLE_API_DOCS=true
ENABLE_MONITORING=true

# ========== 日志配置 ==========
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=./logs/app.log

# ========== 性能配置 ==========
CACHE_TTL=3600
MAX_REQUEST_SIZE=10mb
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# ========== 外部服务配置 ==========

# GitHub (如果需要)
GITHUB_TOKEN=your_github_token_here
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# OpenAI (如果需要)
OPENAI_API_KEY=your_openai_api_key_here

# Google Analytics
GOOGLE_ANALYTICS_ID=your_ga_id_here

# 邮件服务 (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@yourdomain.com

# ========== 监控配置 ==========

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# ========== 备份配置 ==========
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点
BACKUP_RETENTION_DAYS=30

# ========== 维护模式 ==========
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=系统维护中，请稍后访问

# ========== 调试配置 ==========
DEBUG=false
NEXT_PUBLIC_DEBUG=false

# ========== 自定义配置 ==========
# 在这里添加你的自定义配置
APP_NAME=Mission Control
APP_VERSION=2.0.0
APP_DESCRIPTION=智能工具中心 - 一个中心，无限扩展